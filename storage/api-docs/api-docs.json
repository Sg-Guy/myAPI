        "/api/products/store": {
            "post": {
                "tags": [
                    "Products"
                ],
                "description": "Création de nouveau produit",
                "operationId": "90841008e6d2f8cb3655547d2377fb01",
                "requestBody": {
                    "required": true,
                    "content": {
                        "multipart/form-data": {
                            "schema": {
                                "required": [
                                    "category_id",
                                    "nom",
                                    "description",
                                    "stock",
                                    "prix_unitaire",
                                    "image"
                                ],
                                "properties": {
                                    "category_id": {
                                        "description": "Doit être une catégorie existante !",
                                        "type": "integer",
                                        "example": 1
                                    },
                                    "nom": {
                                        "type": "string",
                                        "example": "PC"
                                    },
                                    "description": {
                                        "type": "string",
                                        "example": "PC authentique"
                                    },
                                    "stock": {
                                        "type": "integer",
                                        "example": 20
                                    },
                                    "prix_unitaire": {
                                        "type": "number",
                                        "format": "float",
                                        "example": 100000
                                    },
                                    "prix_promo": {
                                        "description": "Optionnel",
                                        "type": "number",
                                        "format": "float",
                                        "example": 90000
                                    },
                                    "image": {
                                        "type": "string",
                                        "format": "binary",
                                        "example": "url/vers/image"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Création effectuée",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "properties": {
                                            "category_id": {
                                                "description": "Doit être une catégorie existante !",
                                                "type": "integer",
                                                "example": "Informatique"
                                            },
                                            "nom": {
                                                "type": "string",
                                                "example": "PC"
                                            },
                                            "description": {
                                                "type": "string",
                                                "example": "PC authentique"
                                            },
                                            "stock": {
                                                "type": "integer",
                                                "example": 20
                                            },
                                            "prix_unitaire": {
                                                "type": "number",
                                                "format": "float",
                                                "example": 100000
                                            },
                                            "prix_promo": {
                                                "description": "Optionnel",
                                                "type": "number",
                                                "format": "float",
                                                "example": 90000
                                            },
                                            "image": {
                                                "type": "string",
                                                "example": "url/vers/image"
