                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Requête traitée avec succès"
                                        },
                                        "data": {
                                            "type": "array",
                                            "items": {
                                                "properties": {
                                                    "id": {
                                                        "type": "integer",
                                                        "example": 1
